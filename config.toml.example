# DevMate Configuration Template
# Copy this file to config.toml and fill in your API keys

[model]
base_url = "https://api.deepseek.com"
api_key = "YOUR_DEEPSEEK_API_KEY_HERE"
model_name = "deepseek-chat"
embedding_model_name = "text-embedding-3-small"
temperature = 0.7
max_tokens = 4096

[search]
tavily_api_key = "YOUR_TAVILY_API_KEY_HERE"
max_results = 5
mcp_url = "http://localhost:8001/mcp"

[langsmith]
enabled = true
langchain_tracing_v2 = true
langchain_api_key = "YOUR_LANGSMITH_API_KEY_HERE"
langchain_project = "devmate"
project_name = "devmate"

[embedding]
provider = "openai"
api_key = "YOUR_EMBEDDING_API_KEY_HERE"
model_name = "text-embedding-3-small"
base_url = "https://api.openai.com/v1"

[rag]
docs_directory = "docs"
chroma_persist_directory = ".chroma_db"
chunk_size = 1000
chunk_overlap = 200

[skills]
directory = ".skills"
skills_dir = ".skills"
auto_register = true

[output]
workspace_dir = "./output"

[vision]
# 图像理解专用 LLM 配置（必须支持 vision 能力）
# 如果不配置，默认使用 [model] 的配置
base_url = "https://api.moonshot.cn/v1"
api_key = "YOUR_MOONSHOT_API_KEY_HERE"
model_name = "kimi-k2.5"

[mcp_server]
host = "0.0.0.0"
port = 8001
route = "/mcp"
